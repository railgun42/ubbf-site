---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⚠️ À REMPLACER par ta clé Web3Forms (voir instructions en bas de page).
// Obtenir la clé gratuitement sur https://web3forms.com → entre ton email → tu reçois une access key.
const WEB3FORMS_KEY = "VOTRE_ACCESS_KEY_ICI";
---

<BaseLayout
  title="Nous contacter"
  description="Contactez l'Union Bouliste de Bellegarde-en-Forez : rejoignez le club, posez vos questions ou venez découvrir la boule lyonnaise. Formulaire, téléphone et email."
>

  <!-- EN-TÊTE -->
  <section class="page-header" aria-label="Nous contacter">
    <div class="container">
      <span class="page-eyebrow">Nous contacter</span>
      <h1>Envie de nous rejoindre ou de nous poser une question ?</h1>
      <p class="page-lead">
        Pour adhérer au club, vous renseigner sur la boule lyonnaise ou
        simplement venir essayer, écrivez-nous ou appelez-nous. Nous
        répondons avec plaisir à tous les curieux comme aux joueurs confirmés.
      </p>
    </div>
  </section>

  <!-- FORMULAIRE + COORDONNÉES -->
  <section class="section-contact" aria-label="Formulaire et coordonnées">
    <div class="container contact-grid">

      <!-- Formulaire -->
      <div class="contact-form-wrap">
        <h2>Écrivez-nous</h2>
        <p class="form-intro">
          Remplissez ce formulaire, votre message nous parviendra
          directement par email.
        </p>

        <form
          action="https://api.web3forms.com/submit"
          method="POST"
          class="contact-form"
          id="contact-form"
        >
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Nouveau message depuis le site UBBF" />
          <input type="hidden" name="from_name" value="Site UBBF" />
          <!-- Anti-spam : champ caché (honeypot) -->
          <input type="checkbox" name="botcheck" class="hidden-honeypot" style="display:none;" tabindex="-1" autocomplete="off" />

          <div class="form-row">
            <label for="nom">Nom et prénom <span aria-hidden="true">*</span></label>
            <input type="text" id="nom" name="name" required autocomplete="name" placeholder="Jean Dupont" />
          </div>

          <div class="form-row-double">
            <div class="form-row">
              <label for="email">Email <span aria-hidden="true">*</span></label>
              <input type="email" id="email" name="email" required autocomplete="email" placeholder="jean.dupont@email.fr" />
            </div>
            <div class="form-row">
              <label for="tel">Téléphone</label>
              <input type="tel" id="tel" name="phone" autocomplete="tel" placeholder="06 12 34 56 78" />
            </div>
          </div>

          <div class="form-row">
            <label for="sujet">Sujet</label>
            <select id="sujet" name="sujet">
              <option value="Adhésion">Je souhaite adhérer au club</option>
              <option value="Découverte">Je veux venir essayer / découvrir</option>
              <option value="Renseignement">Demande de renseignement</option>
              <option value="Autre">Autre</option>
            </select>
          </div>

          <div class="form-row">
            <label for="message">Votre message <span aria-hidden="true">*</span></label>
            <textarea id="message" name="message" rows="5" required placeholder="Bonjour, je souhaiterais..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary form-submit">Envoyer le message</button>

          <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
        </form>
      </div>

      <!-- Coordonnées directes -->
      <aside class="contact-infos" aria-label="Coordonnées directes">
        <h2>Ou contactez-nous directement</h2>

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/>
            </svg>
          </div>
          <div class="info-content">
            <h3>Téléphone</h3>
            <a href="tel:+33000000000" class="info-lien">[06 XX XX XX XX]</a>
          </div>
        </div>

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </div>
          <div class="info-content">
            <h3>Email</h3>
            <a href="mailto:contact@ubbf.fr" class="info-lien">[contact@ubbf.fr]</a>
          </div>
        </div>

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="info-content">
            <h3>Adresse</h3>
            <p>[Nom du boulodrome]<br />42210 Bellegarde-en-Forez</p>
            <a href="/acces" class="info-lien-sec">Voir le plan d'accès →</a>
          </div>
        </div>

        <div class="contact-facebook">
          <p>Suivez aussi notre actualité au quotidien :</p>
          <a
            href="https://www.facebook.com/UnionBoulisteBellegardeEnForez"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-facebook"
            aria-label="Page Facebook de l'UBBF (nouvel onglet)"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Page Facebook
          </a>
        </div>
      </aside>

    </div>
  </section>

</BaseLayout>

<script>
  // Envoi du formulaire en AJAX pour rester sur le site (pas de redirection Web3Forms)
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('form-status');

  if (form && status) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = form.querySelector('.form-submit') as HTMLButtonElement;
      submitBtn.disabled = true;
      submitBtn.textContent = 'Envoi en cours...';
      status.textContent = '';
      status.className = 'form-status';

      try {
        const formData = new FormData(form);
        const res = await fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          body: formData,
        });
        const data = await res.json();

        if (data.success) {
          status.textContent = 'Merci ! Votre message a bien été envoyé. Nous vous répondrons rapidement.';
          status.classList.add('form-status--ok');
          form.reset();
        } else {
          status.textContent = "Une erreur est survenue. Réessayez ou contactez-nous par téléphone.";
          status.classList.add('form-status--error');
        }
      } catch {
        status.textContent = "Impossible d'envoyer le message. Vérifiez votre connexion ou appelez-nous.";
        status.classList.add('form-status--error');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Envoyer le message';
      }
    });
  }
</script>

<style>

  /* ── En-tête ─────────────────────────────────────────────── */
  .page-header {
    background: var(--vert-ubbf);
    padding: 3.5rem 0;
  }
  .page-eyebrow {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 4px 14px;
    border-radius: var(--radius-full);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .page-header h1 {
    color: var(--blanc);
    font-size: clamp(1.5rem, 3.5vw, 2.25rem);
    line-height: 1.2;
    margin-bottom: 1rem;
    max-width: 720px;
  }
  .page-lead {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-lg);
    line-height: 1.7;
    max-width: 640px;
  }

  /* ── Section contact ─────────────────────────────────────── */
  .section-contact {
    padding: 4rem 0;
    background: var(--blanc);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* ── Formulaire ──────────────────────────────────────────── */
  .contact-form-wrap h2 {
    margin-bottom: 0.5rem;
  }
  .form-intro {
    color: var(--gris-texte);
    margin-bottom: 1.75rem;
  }
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .form-row {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }
  .form-row-double {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }
  .form-row label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--noir);
  }
  .form-row label span {
    color: var(--vert-ubbf);
  }
  .form-row input,
  .form-row select,
  .form-row textarea {
    width: 100%;
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--gris-border);
    border-radius: var(--radius-md);
    font-family: inherit;
    font-size: var(--text-base);
    color: var(--noir);
    background: var(--blanc);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .form-row input:focus,
  .form-row select:focus,
  .form-row textarea:focus {
    outline: none;
    border-color: var(--vert-ubbf);
    box-shadow: 0 0 0 3px rgba(26,122,60,0.12);
  }
  .form-row textarea {
    resize: vertical;
    min-height: 120px;
  }
  .form-submit {
    align-self: flex-start;
    margin-top: 0.25rem;
    cursor: pointer;
  }
  .form-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .form-status {
    font-size: var(--text-sm);
    line-height: 1.5;
    margin: 0;
  }
  .form-status--ok {
    color: #15803d;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
  }
  .form-status--error {
    color: #b91c1c;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
  }

  /* ── Coordonnées ─────────────────────────────────────────── */
  .contact-infos {
    background: var(--gris-bg);
    border: 1px solid var(--gris-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
  }
  .contact-infos h2 {
    font-size: var(--text-lg);
    margin-bottom: 1.5rem;
  }
  .info-bloc {
    display: flex;
    gap: 0.875rem;
    align-items: flex-start;
    margin-bottom: 1.5rem;
  }
  .info-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--vert-pale);
    color: var(--vert-ubbf);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .info-content h3 {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--noir);
    margin-bottom: 0.125rem;
  }
  .info-content p {
    color: var(--gris-texte);
    font-size: var(--text-sm);
    line-height: 1.5;
  }
  .info-lien {
    color: var(--vert-ubbf);
    font-weight: 500;
    font-size: var(--text-base);
    transition: opacity 0.15s;
  }
  .info-lien:hover {
    opacity: 0.75;
    text-decoration: underline;
  }
  .info-lien-sec {
    display: inline-block;
    color: var(--vert-ubbf);
    font-size: var(--text-sm);
    font-weight: 500;
    margin-top: 0.375rem;
    transition: opacity 0.15s;
  }
  .info-lien-sec:hover {
    opacity: 0.75;
  }

  .contact-facebook {
    border-top: 1px solid var(--gris-border);
    padding-top: 1.5rem;
    margin-top: 0.5rem;
  }
  .contact-facebook p {
    font-size: var(--text-sm);
    color: var(--gris-texte);
    margin-bottom: 0.875rem;
  }
  .btn-facebook {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 44px;
    padding: 0 1.25rem;
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    background: #1877F2;
    color: var(--blanc);
    transition: background 0.15s;
  }
  .btn-facebook:hover {
    background: #1461c8;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .form-row-double {
      grid-template-columns: 1fr;
    }
  }
</style>