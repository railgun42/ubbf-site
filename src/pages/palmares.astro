---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Palmarès"
  description="Le palmarès de l'Union Bouliste de Bellegarde-en-Forez : titres, podiums et résultats de nos équipes de boule lyonnaise en championnat et en concours."
>

  <!-- EN-TÊTE -->
  <section class="page-header" aria-label="Palmarès">
    <div class="container">
      <span class="page-eyebrow">Palmarès</span>
      <h1>Nos résultats, saison après saison</h1>
      <p class="page-lead">
        Championnats, concours et coupes : retrouvez les performances
        des équipes de l'UBB. Un palmarès qui témoigne du sérieux et
        de l'engagement de nos joueurs sur les terrains du Forez et d'ailleurs.
      </p>
    </div>
  </section>

  <!-- CHIFFRES CLÉS -->
  <section class="section-chiffres" aria-label="Chiffres clés du palmarès">
    <div class="container">
      <ul class="chiffres-grid" role="list">
        <li class="chiffre-card">
          <span class="chiffre-number">[N]</span>
          <span class="chiffre-label">titres remportés</span>
        </li>
        <li class="chiffre-card">
          <span class="chiffre-number">[N]</span>
          <span class="chiffre-label">podiums cette saison</span>
        </li>
        <li class="chiffre-card">
          <span class="chiffre-number">[N]</span>
          <span class="chiffre-label">équipes qualifiées</span>
        </li>
        <li class="chiffre-card">
          <span class="chiffre-number">[ANNÉE]</span>
          <span class="chiffre-label">depuis nos débuts</span>
        </li>
      </ul>
    </div>
  </section>

  <!-- PALMARÈS PAR SAISON -->
  <section class="section-saisons" aria-labelledby="titre-saisons">
    <div class="container">
      <div class="saisons-header">
        <span class="bloc-tag">Saison par saison</span>
        <h2 id="titre-saisons">Les temps forts de l'UBB</h2>
        <p class="saisons-intro">
          Une sélection des meilleurs résultats du club. Pour suivre
          l'actualité des compétitions en temps réel, rendez-vous sur
          notre page Facebook.
        </p>
      </div>

      <!-- SAISON 2024-2025 -->
      <article class="saison-bloc">
        <div class="saison-annee">
          <h3>Saison 2024-2025</h3>
          <span class="saison-badge">Saison en cours</span>
        </div>
        <ul class="resultats-liste" role="list">
          <li class="resultat-item">
            <span class="resultat-medaille medaille-or" aria-label="Première place">1<sup>er</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
          <li class="resultat-item">
            <span class="resultat-medaille medaille-argent" aria-label="Deuxième place">2<sup>e</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
          <li class="resultat-item">
            <span class="resultat-medaille medaille-bronze" aria-label="Troisième place">3<sup>e</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
        </ul>
      </article>

      <!-- SAISON 2023-2024 -->
      <article class="saison-bloc">
        <div class="saison-annee">
          <h3>Saison 2023-2024</h3>
        </div>
        <ul class="resultats-liste" role="list">
          <li class="resultat-item">
            <span class="resultat-medaille medaille-or" aria-label="Première place">1<sup>er</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
          <li class="resultat-item">
            <span class="resultat-medaille medaille-argent" aria-label="Deuxième place">2<sup>e</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
        </ul>
      </article>

      <!-- SAISON 2022-2023 -->
      <article class="saison-bloc">
        <div class="saison-annee">
          <h3>Saison 2022-2023</h3>
        </div>
        <ul class="resultats-liste" role="list">
          <li class="resultat-item">
            <span class="resultat-medaille medaille-or" aria-label="Première place">1<sup>er</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
          <li class="resultat-item">
            <span class="resultat-medaille medaille-bronze" aria-label="Troisième place">3<sup>e</sup></span>
            <div class="resultat-info">
              <p class="resultat-titre">[Nom de la compétition]</p>
              <p class="resultat-detail">[Catégorie / équipe] · [Lieu]</p>
            </div>
          </li>
        </ul>
      </article>

    </div>
  </section>

  <!-- NOTE FACEBOOK -->
  <section class="section-note" aria-label="Suivre les résultats">
    <div class="container note-inner">
      <div class="note-icon" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M8 2v4"/><path d="M16 2v4"/><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M3 10h18"/><path d="m9 16 2 2 4-4"/>
        </svg>
      </div>
      <div class="note-text">
        <h2>Suivez nos résultats en direct</h2>
        <p>
          Le palmarès est mis à jour à la fin de chaque saison. Pour les
          résultats des concours au fil de l'eau, notre page Facebook
          reste la source la plus réactive.
        </p>
      </div>
      <a
        href="https://www.facebook.com/UnionBoulisteBellegardeEnForez"
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn-primary"
        aria-label="Suivre l'UBBF sur Facebook (nouvel onglet)"
      >
        Page Facebook →
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cta" aria-label="Rejoindre le club">
    <div class="container cta-inner">
      <div>
        <h2>Envie d'écrire la suite avec nous ?</h2>
        <p>
          Rejoignez l'UBB et défendez les couleurs de Bellegarde-en-Forez
          sur les terrains de la région.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-white">Nous rejoindre</a>
        <a href="/le-club" class="btn btn-outline-white">Découvrir le club →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>

  /* ── En-tête ─────────────────────────────────────────────── */
  .page-header {
    background: var(--vert-ubbf);
    padding: 3.5rem 0;
  }
  .page-eyebrow {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 4px 14px;
    border-radius: var(--radius-full);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .page-header h1 {
    color: var(--blanc);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 700px;
  }
  .page-lead {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-lg);
    line-height: 1.7;
    max-width: 640px;
  }

  /* ── Chiffres clés ───────────────────────────────────────── */
  .section-chiffres {
    background: var(--blanc);
    border-bottom: 1px solid var(--gris-border);
    padding: 2.5rem 0;
  }
  .chiffres-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 1.5rem;
  }
  .chiffre-card {
    text-align: center;
  }
  .chiffre-number {
    display: block;
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--vert-ubbf);
    line-height: 1;
  }
  .chiffre-label {
    display: block;
    font-size: var(--text-sm);
    color: var(--gris-muted);
    margin-top: 0.5rem;
  }

  /* ── Saisons ─────────────────────────────────────────────── */
  .section-saisons {
    padding: 4rem 0;
    background: var(--gris-bg);
  }
  .saisons-header {
    margin-bottom: 2.5rem;
  }
  .bloc-tag {
    display: block;
    color: var(--vert-ubbf);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .saisons-header h2 {
    margin-bottom: 0.75rem;
  }
  .saisons-intro {
    color: var(--gris-texte);
    max-width: 560px;
  }

  .saison-bloc {
    background: var(--blanc);
    border: 1px solid var(--gris-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem;
    margin-bottom: 1.25rem;
  }
  .saison-bloc:last-child {
    margin-bottom: 0;
  }
  .saison-annee {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--gris-border);
  }
  .saison-annee h3 {
    font-size: var(--text-xl);
    color: var(--noir);
  }
  .saison-badge {
    background: var(--vert-pale);
    color: var(--vert-ubbf);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .resultats-liste {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .resultat-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .resultat-medaille {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--blanc);
  }
  .resultat-medaille sup {
    font-size: 0.6em;
  }
  .medaille-or {
    background: #d4a017;
  }
  .medaille-argent {
    background: #9ca3af;
  }
  .medaille-bronze {
    background: #b87333;
  }
  .resultat-info {
    flex: 1;
  }
  .resultat-titre {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--noir);
    line-height: 1.3;
  }
  .resultat-detail {
    font-size: var(--text-sm);
    color: var(--gris-muted);
    margin-top: 2px;
  }

  /* ── Note Facebook ───────────────────────────────────────── */
  .section-note {
    padding: 3rem 0;
    background: var(--blanc);
  }
  .note-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    background: var(--gris-bg);
    border: 1px solid var(--gris-border);
    border-radius: var(--radius-lg);
    padding: 1.75rem 2rem;
  }
  .note-icon {
    flex-shrink: 0;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--vert-pale);
    color: var(--vert-ubbf);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .note-text {
    flex: 1;
  }
  .note-text h2 {
    font-size: var(--text-lg);
    margin-bottom: 0.375rem;
  }
  .note-text p {
    color: var(--gris-texte);
    font-size: var(--text-sm);
    line-height: 1.6;
  }
  .note-inner .btn {
    flex-shrink: 0;
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .section-cta {
    background: var(--vert-ubbf);
    padding: 3rem 0;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .section-cta h2 {
    color: var(--blanc);
    font-size: var(--text-2xl);
    margin-bottom: 0.5rem;
  }
  .section-cta p {
    color: rgba(255,255,255,0.85);
    max-width: 480px;
  }
  .cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .note-inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-actions {
      justify-content: center;
    }
  }
</style>