---
import BaseLayout from '../layouts/BaseLayout.astro';

// ⚠️ COORDONNÉES À REMPLACER par celles du vrai boulodrome.
// Pour les trouver : openstreetmap.org → chercher l'adresse → clic droit → "Centrer la carte ici" → l'URL contient #map=18/LAT/LON
const lat = 45.644869;   // ← latitude du boulodrome (placeholder : centre de Bellegarde-en-Forez)
const lon = 4.29772 ;    // ← longitude du boulodrome
const zoom = 16;

// Bounding box pour l'iframe OpenStreetMap (petite marge autour du point)
const d = 0.008;
const bbox = `${lon - d},${lat - d},${lon + d},${lat + d}`;
---

<BaseLayout
  title="Nous trouver"
  description="Le boulodrome de l'Union Bouliste de Bellegarde-en-Forez : adresse, plan d'accès, horaires d'entraînement et contact. Boule lyonnaise dans la Loire."
>

  <!-- EN-TÊTE -->
  <section class="page-header" aria-label="Nous trouver">
    <div class="container">
      <span class="page-eyebrow">Nous trouver</span>
      <h1>Venez nous voir au boulodrome</h1>
      <p class="page-lead">
        Le club vous accueille à Bellegarde-en-Forez. Que vous veniez
        jouer, vous renseigner ou simplement assister à un concours,
        l'entrée est libre et les portes sont ouvertes.
      </p>
    </div>
  </section>

  <!-- CARTE + INFOS -->
  <section class="section-acces" aria-label="Plan d'accès et coordonnées">
    <div class="container acces-grid">

      <!-- Carte -->
      <div class="acces-carte">
        <iframe
          title="Carte du boulodrome de l'UBBF à Bellegarde-en-Forez"
          width="100%"
          height="100%"
          loading="lazy"
          style="border:0;"
          src={`https://www.openstreetmap.org/export/embed.html?bbox=${bbox}&layer=mapnik&marker=${lat},${lon}`}
        ></iframe>
      </div>

      <!-- Coordonnées -->
      <div class="acces-infos">

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="info-content">
            <h2>Adresse</h2>
            <p>
              [Nom du boulodrome]<br />
              [Numéro et rue]<br />
              42210 Bellegarde-en-Forez
            </p>
          </div>
        </div>

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92Z"/>
            </svg>
          </div>
          <div class="info-content">
            <h2>Téléphone</h2>
            <p>
              <a href="tel:+33000000000" class="info-lien">[06 XX XX XX XX]</a>
            </p>
          </div>
        </div>

        <div class="info-bloc">
          <div class="info-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </div>
          <div class="info-content">
            <h2>Email</h2>
            <p>
              <a href="mailto:contact@ubbf.fr" class="info-lien">[contact@ubbf.fr]</a>
            </p>
          </div>
        </div>

        <a
          href={`https://www.openstreetmap.org/?mlat=${lat}&mlon=${lon}#map=${zoom}/${lat}/${lon}`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary acces-itineraire"
          aria-label="Ouvrir l'itinéraire dans OpenStreetMap (nouvel onglet)"
        >
          Voir l'itinéraire →
        </a>

      </div>

    </div>
  </section>

  <!-- HORAIRES -->
  <section class="section-horaires" aria-labelledby="titre-horaires">
    <div class="container">
      <div class="horaires-header">
        <span class="bloc-tag">Horaires</span>
        <h2 id="titre-horaires">Quand venir jouer</h2>
        <p class="horaires-intro">
          Les créneaux d'entraînement sont ouverts à tous les licenciés.
          Pour une première découverte, présentez-vous simplement sur place
          ou contactez-nous au préalable.
        </p>
      </div>

      <ul class="horaires-liste" role="list">
        <li class="horaire-item">
          <span class="horaire-jour">Lundi</span>
          <span class="horaire-creneau">[Horaire ou « Fermé »]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Mardi</span>
          <span class="horaire-creneau">[14h00 – 18h00]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Mercredi</span>
          <span class="horaire-creneau">[Horaire ou « Fermé »]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Jeudi</span>
          <span class="horaire-creneau">[14h00 – 18h00]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Vendredi</span>
          <span class="horaire-creneau">[Horaire ou « Fermé »]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Samedi</span>
          <span class="horaire-creneau">[Concours / sur planning]</span>
        </li>
        <li class="horaire-item">
          <span class="horaire-jour">Dimanche</span>
          <span class="horaire-creneau">[Concours / sur planning]</span>
        </li>
      </ul>

      <p class="horaires-note">
        Les jours de concours, les horaires peuvent varier. Consultez notre
        page Facebook pour le calendrier à jour.
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section-cta" aria-label="Nous contacter">
    <div class="container cta-inner">
      <div>
        <h2>Une question avant de venir ?</h2>
        <p>
          N'hésitez pas à nous contacter, nous serons ravis de vous
          renseigner et de vous accueillir au club.
        </p>
      </div>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-white">Nous contacter</a>
        <a href="/le-club" class="btn btn-outline-white">Le club →</a>
      </div>
    </div>
  </section>

</BaseLayout>

<style>

  /* ── En-tête ─────────────────────────────────────────────── */
  .page-header {
    background: var(--vert-ubbf);
    padding: 3.5rem 0;
  }
  .page-eyebrow {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.9);
    font-size: var(--text-xs);
    font-weight: 600;
    padding: 4px 14px;
    border-radius: var(--radius-full);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .page-header h1 {
    color: var(--blanc);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 700px;
  }
  .page-lead {
    color: rgba(255,255,255,0.85);
    font-size: var(--text-lg);
    line-height: 1.7;
    max-width: 640px;
  }

  /* ── Accès (carte + infos) ───────────────────────────────── */
  .section-acces {
    padding: 4rem 0;
    background: var(--blanc);
  }
  .acces-grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 2.5rem;
    align-items: stretch;
  }
  .acces-carte {
    min-height: 420px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 3px solid var(--vert-pale-border);
    background: var(--vert-pale);
  }
  .acces-carte iframe {
    display: block;
  }
  .acces-infos {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }
  .info-bloc {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }
  .info-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--vert-pale);
    color: var(--vert-ubbf);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .info-content h2 {
    font-size: var(--text-base);
    font-weight: 600;
    margin-bottom: 0.25rem;
  }
  .info-content p {
    color: var(--gris-texte);
    line-height: 1.6;
  }
  .info-lien {
    color: var(--vert-ubbf);
    font-weight: 500;
    transition: opacity 0.15s;
  }
  .info-lien:hover {
    opacity: 0.75;
    text-decoration: underline;
  }
  .acces-itineraire {
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  /* ── Horaires ────────────────────────────────────────────── */
  .section-horaires {
    padding: 4rem 0;
    background: var(--gris-bg);
  }
  .horaires-header {
    margin-bottom: 2rem;
  }
  .bloc-tag {
    display: block;
    color: var(--vert-ubbf);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .horaires-header h2 {
    margin-bottom: 0.75rem;
  }
  .horaires-intro {
    color: var(--gris-texte);
    max-width: 560px;
  }
  .horaires-liste {
    background: var(--blanc);
    border: 1px solid var(--gris-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    max-width: 520px;
  }
  .horaire-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.875rem 1.25rem;
    border-bottom: 1px solid var(--gris-border);
  }
  .horaire-item:last-child {
    border-bottom: none;
  }
  .horaire-jour {
    font-weight: 500;
    color: var(--noir);
  }
  .horaire-creneau {
    color: var(--gris-texte);
    font-size: var(--text-sm);
  }
  .horaires-note {
    margin-top: 1.25rem;
    font-size: var(--text-sm);
    color: var(--gris-muted);
    max-width: 520px;
  }

  /* ── CTA ─────────────────────────────────────────────────── */
  .section-cta {
    background: var(--vert-ubbf);
    padding: 3rem 0;
  }
  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .section-cta h2 {
    color: var(--blanc);
    font-size: var(--text-2xl);
    margin-bottom: 0.5rem;
  }
  .section-cta p {
    color: rgba(255,255,255,0.85);
    max-width: 480px;
  }
  .cta-actions {
    display: flex;
    gap: 0.75rem;
    flex-shrink: 0;
    flex-wrap: wrap;
  }

  /* ── Responsive ──────────────────────────────────────────── */
  @media (max-width: 768px) {
    .acces-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .acces-carte {
      min-height: 300px;
    }
    .cta-inner {
      flex-direction: column;
      text-align: center;
    }
    .cta-actions {
      justify-content: center;
    }
  }
</style>